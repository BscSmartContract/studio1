
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SAI PADUKA PORTAL - FIREBASE SECURITY RULES
     * 
     * Admin access is granted exclusively to theroasterop1@gmail.com
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "theroasterop1@gmail.com";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{adminUid} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /app_configuration/{configId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /users/{userId}/volunteers/{volunteerId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.externalAuthUserId == userId;
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    match /users/{userId}/darshan_registrations/{registrationId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.externalAuthUserId == userId;
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    // Collection Group rules (Crucial for Admin Panel)
    match /{path=**}/darshan_registrations/{registrationId} {
      allow list: if isAdmin();
    }

    match /{path=**}/volunteers/{volunteerId} {
      allow list: if isAdmin();
    }

    match /prominent_donors/{donorId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /daily_blessing_photos/{photoId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /subscribers/{subscriberId} {
      allow create: if true;
      // Allow public to check if they are already registered by email/phone
      allow list: if true;
      allow get, delete: if isAdmin();
    }

    // Support for 'Stay Tuned' OTP verification
    match /verification_codes/{email} {
      allow create, get, update: if true;
      allow list, delete: if isAdmin();
    }

    // Support for 'Trigger Email' Extension
    match /mail/{mailId} {
      // Allow authenticated users to see their own emails, or admin to see all
      allow get: if (isSignedIn() && resource.data.to == request.auth.token.email) || isAdmin();
      // Allow public creation so unauthenticated users can trigger OTP/Confirmation emails
      allow create: if true;
      allow list, update, delete: if isAdmin();
    }
  }
}
