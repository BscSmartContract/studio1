
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SAI BABA TEMPLE TRUST - FIREBASE SECURITY RULES
     * 
     * Admin access is granted exclusively to theroasterop1@gmail.com
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "theroasterop1@gmail.com";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{adminUid} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /app_configuration/{configId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Individual document rules
    match /users/{userId}/volunteers/{volunteerId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.externalAuthUserId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.externalAuthUserId == resource.data.externalAuthUserId;
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    match /users/{userId}/darshan_registrations/{registrationId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.externalAuthUserId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.externalAuthUserId == resource.data.externalAuthUserId;
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    // Collection Group rules (Crucial for Admin Panel)
    match /{path=**}/darshan_registrations/{registrationId} {
      allow list: if isAdmin();
    }

    match /{path=**}/volunteers/{volunteerId} {
      allow list: if isAdmin();
    }

    match /donation_purposes/{purposeId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /prominent_donors/{donorId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /gallery_images/{imageId} {
      allow get, list: if (resource == null || resource.data.isVisible == true) || isAdmin();
      allow write: if isAdmin();
    }

    match /daily_blessing_photos/{photoId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
  }
}
