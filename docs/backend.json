
{
  "entities": {
    "AppConfiguration": {
      "title": "AppConfiguration",
      "type": "object",
      "description": "Stores global configuration settings.",
      "properties": {
        "heroImageUrl": { "type": "string", "format": "uri" },
        "eventName": { "type": "string" },
        "eventDate": { "type": "string", "format": "date" },
        "organizerName": { "type": "string" },
        "liveDarshanYoutubeLink": { "type": "string", "format": "uri" },
        "lastUpdatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["eventName", "organizerName", "lastUpdatedAt"]
    },
    "Volunteer": {
      "title": "Volunteer",
      "type": "object",
      "description": "Volunteer registration details.",
      "properties": {
        "id": { "type": "string" },
        "externalAuthUserId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "areaOfService": { "type": "array", "items": { "type": "string" } },
        "registrationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["externalAuthUserId", "name", "phoneNumber", "registrationDate"]
    },
    "DarshanRegistration": {
      "title": "DarshanRegistration",
      "type": "object",
      "description": "Darshan group registration.",
      "properties": {
        "id": { "type": "string" },
        "externalAuthUserId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "totalPeople": { "type": "number" },
        "devotees": { "type": "array", "items": { "type": "object" } },
        "registrationDate": { "type": "string", "format": "date-time" },
        "isCheckedIn": { "type": "boolean" }
      },
      "required": ["externalAuthUserId", "userName", "totalPeople", "registrationDate"]
    },
    "Donor": {
      "title": "Donor",
      "type": "object",
      "description": "Prominent donor details.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "city": { "type": "string" },
        "category": { "type": "string" },
        "displayOrder": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category"]
    },
    "GalleryImage": {
      "title": "GalleryImage",
      "type": "object",
      "description": "An image for the public gallery.",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "isVisible": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl", "description", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/app_configuration/main": {
      "schema": "AppConfiguration",
      "description": "Global config singleton."
    },
    "/users/{userId}/volunteers/{volunteerId}": {
      "schema": "Volunteer",
      "description": "Volunteer records."
    },
    "/users/{userId}/darshan_registrations/{registrationId}": {
      "schema": "DarshanRegistration",
      "description": "Darshan records."
    },
    "/prominent_donors/{donorId}": {
      "schema": "Donor",
      "description": "Wall of Gratitude donors."
    },
    "/gallery_images/{imageId}": {
      "schema": "GalleryImage",
      "description": "Public photo gallery."
    }
  }
}
